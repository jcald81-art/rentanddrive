{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build",
  "framework": "nextjs",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/rad-comms",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/rad-pricing",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/rad-shield",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/rad-commandcontrol",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/rad-pulse",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/rad-funtime",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/morning-brief",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/fleet-health",
      "schedule": "0 0 * * 0"
    },
    {
      "path": "/api/cron/model-health",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/dispatch-scheduled-rides",
      "schedule": "*/5 * * * *"
    }
  ]
}

# ==============================================================================
# RentAndDrive LLC — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase (Required)
# Get from: https://app.supabase.com → Project Settings → API
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------------------------
# Stripe (Required for payments)
# Get from: https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Identity (for driver license verification)
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...
# Stripe Connect (for host payouts)
STRIPE_CONNECT_CLIENT_ID=ca_...

# ------------------------------------------------------------------------------
# AI Models (at least one required for AI agents)
# Vercel AI Gateway (recommended — zero-config for OpenAI/Anthropic/Google)
# ------------------------------------------------------------------------------
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
# xAI Grok (primary AI model for RAD agents)
XAI_API_KEY=xai-...
# OpenAI (fallback)
OPENAI_API_KEY=sk-...
# Anthropic Claude (optional fallback)
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------------------------
# Bouncie GPS / RADar Fleet Tracking
# Get from: https://www.bouncie.com/developers
# ------------------------------------------------------------------------------
BOUNCIE_CLIENT_ID=your-bouncie-client-id
BOUNCIE_CLIENT_SECRET=your-bouncie-client-secret
BOUNCIE_WEBHOOK_SECRET=your-bouncie-webhook-secret
# OAuth redirect for Bouncie host device linking
BOUNCIE_REDIRECT_URI=https://rentanddrive.com/api/bouncie/callback

# ------------------------------------------------------------------------------
# igloohome Smart Lockboxes
# Get from: https://developer.igloohome.co
# ------------------------------------------------------------------------------
IGLOO_API_KEY=your-igloohome-api-key
IGLOO_API_SECRET=your-igloohome-api-secret

# ------------------------------------------------------------------------------
# Inspektlabs AI Vehicle Inspections
# Get from: https://inspektlabs.com/developers
# ------------------------------------------------------------------------------
INSPEKTLABS_API_KEY=your-inspektlabs-api-key
INSPEKTLABS_CLIENT_ID=your-inspektlabs-client-id
INSPEKTLABS_WEBHOOK_SECRET=your-inspektlabs-webhook-secret

# ------------------------------------------------------------------------------
# Checkr Driver Background + MVR Screening
# Get from: https://dashboard.checkr.com/account/api-keys
# ------------------------------------------------------------------------------
CHECKR_API_KEY=your-checkr-api-key
CHECKR_WEBHOOK_SECRET=your-checkr-webhook-secret
# Checkr package slug for MVR reports
CHECKR_MVR_PACKAGE=driver_pro
# FCRA-required: your company's name shown on adverse action notices
CHECKR_COMPANY_NAME=RentAndDrive LLC

# ------------------------------------------------------------------------------
# Uber Direct (Vehicle Delivery)
# Get from: https://developer.uber.com → Uber Direct / Uber for Business
# ------------------------------------------------------------------------------
UBER_CLIENT_ID=your-uber-client-id
UBER_CLIENT_SECRET=your-uber-client-secret
UBER_CUSTOMER_ID=your-uber-direct-customer-id
# Uber Direct server token
UBER_SERVER_TOKEN=your-uber-server-token
# Used by /integrations/uber-direct.ts
UBER_DIRECT_CLIENT_ID=your-uber-direct-client-id
UBER_DIRECT_CLIENT_SECRET=your-uber-direct-client-secret

# ------------------------------------------------------------------------------
# Lyft Concierge (Vehicle Delivery — primary)
# Get from: https://developer.lyft.com
# ------------------------------------------------------------------------------
LYFT_CLIENT_ID=your-lyft-client-id
LYFT_CLIENT_SECRET=your-lyft-client-secret
# Lyft API key for Concierge
LYFT_API_KEY=your-lyft-api-key

# ------------------------------------------------------------------------------
# Twilio (SMS Notifications)
# Get from: https://console.twilio.com
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+17755550000

# ------------------------------------------------------------------------------
# SendGrid (Email)
# Get from: https://app.sendgrid.com/settings/api_keys
# ------------------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@rentanddrive.com
SENDGRID_FROM_NAME=Rent and Drive

# ------------------------------------------------------------------------------
# Upstash Redis (Caching + Rate Limiting)
# Get from: https://console.upstash.com
# ------------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ------------------------------------------------------------------------------
# App Configuration
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://rentanddrive.com
NEXT_PUBLIC_APP_NAME=Rent and Drive
# Cron job secret (generate a random string)
CRON_SECRET=your-random-cron-secret
# JWT secret for internal API calls
INTERNAL_API_SECRET=your-random-internal-secret

# ------------------------------------------------------------------------------
# Reno-Specific Geofence Configuration (Optional — has defaults)
# ------------------------------------------------------------------------------
# RNO Airport geofence radius in meters
GEOFENCE_AIRPORT_RADIUS_M=2000
# Tahoe corridor bounding box
GEOFENCE_TAHOE_MIN_LAT=38.9
GEOFENCE_TAHOE_MAX_LAT=39.4
GEOFENCE_TAHOE_MIN_LNG=-120.2
GEOFENCE_TAHOE_MAX_LNG=-119.7
